# ===== env ของ backend container (env_file ใน compose) =====
# คัดลอกเป็น deploy/backend.env แล้วใส่ค่าจริง — *อย่า commit*
# หมายเหตุ: NODE_ENV, PORT, MONGODB_URI, MONGODB_DB ถูกตั้งใน docker-compose.yml แล้ว (ไม่ต้องใส่ที่นี่)
# NODE_ENV=production จะเปิด guard: JWT_SECRET/VIDEO_GRANT_SECRET ต้องยาว >=32 + ไม่ใช่ค่า dev,
#   COOKIE_SECURE ต้อง true, VIDEO_BASE_URL ต้องเป็น https — ไม่งั้น backend จะไม่บูต

# ---- App session (สุ่มยาว >= 32 ตัว) ----
JWT_SECRET=CHANGE_ME_random_at_least_32_chars_xxxxxxxx
SESSION_COOKIE_NAME=mdn_session
ADMIN_COOKIE_NAME=mdn_admin
COOKIE_SECURE=true
# app กับ api อยู่โดเมนแม่เดียวกัน (เช่น *.your-domain.com) -> lax + ตั้ง COOKIE_DOMAIN
# ถ้าคนละโดเมน -> none
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=.your-domain.com

# ---- Frontend / CORS ----
FRONTEND_URL=https://app.your-domain.com
CORS_ORIGINS=https://app.your-domain.com

# ---- LINE Login ----
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_LOGIN_REDIRECT_URI=https://api.your-domain.com/auth/line/callback

# ---- Admin (seed) ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_admin_strong_password

# ---- Video (ต้องตรงกับ video-worker) ----
VIDEO_GRANT_SECRET=CHANGE_ME_random_at_least_32_chars_same_as_worker
VIDEO_BASE_URL=https://video.your-domain.com
VIDEO_TOKEN_TTL_SECONDS=120
