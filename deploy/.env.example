# ===== compose-level env (ใช้ตอน docker compose interpolation + backup) =====
# คัดลอกเป็น deploy/.env แล้วใส่ค่าจริง — รันด้วย:
#   docker compose -f deploy/docker-compose.yml --env-file deploy/.env up -d
# *อย่า commit deploy/.env*

# ---- MongoDB ----
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=CHANGE_ME_root_strong_password
# รหัสของ appuser (backend ใช้ตัวนี้ ไม่ใช่ root) — ใช้อักขระ URL-safe (เลี่ยง @ : / ?) หรือ encode ใน URI
MONGO_APP_PASSWORD=CHANGE_ME_app_urlsafe_password

# ---- Cloudflare Tunnel (expose backend เป็น https://api.your-domain.com) ----
CF_TUNNEL_TOKEN=

# ---- Backup -> R2 (ใช้โดย backup-to-r2.sh) ----
R2_BUCKET=mheedoonung-backups
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
RETENTION_DAYS=7
# เข้ารหัส backup ฝั่ง client ก่อนอัป R2 (แนะนำ — dump มีข้อมูลผู้ใช้ทั้ง DB)
#   สร้าง key: age-keygen -o backup-age.key  แล้วเก็บ private key "นอก host นี้"
#   เอาเฉพาะ public key (age1...) มาใส่ตรงนี้ — ถ้าเว้นว่าง archive จะถูกอัปแบบไม่เข้ารหัส (มี WARN)
BACKUP_AGE_RECIPIENT=
