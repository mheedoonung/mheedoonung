# ---- เซิร์ฟเวอร์ ----
PORT=3000

# ---- MongoDB ----
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=mheedoonung

# ---- App session (JWT + cookie) ----
# ตั้งค่าเป็น secret สุ่มยาว ๆ ใน production
JWT_SECRET=dev-secret-change-me
SESSION_COOKIE_NAME=mdn_session
ADMIN_COOKIE_NAME=mdn_admin
# secure=true เฉพาะ HTTPS (prod); dev ใช้ false
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# โดเมนของ cookie (ปล่อยว่างได้สำหรับ dev)
COOKIE_DOMAIN=

# ---- Frontend / CORS ----
FRONTEND_URL=http://localhost:5173
# หลาย origin คั่นด้วย ,
CORS_ORIGINS=http://localhost:5173

# ---- LINE Login ----
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_LOGIN_REDIRECT_URI=http://localhost:3000/auth/line/callback

# ---- Admin (seed) ----
ADMIN_USERNAME=admin
# เปลี่ยนใน prod แน่นอน
ADMIN_PASSWORD=changeme

# ---- วิดีโอ (เฟส 4-5: playback token + video-worker) ----
# secret สำหรับเซ็น grant — ต้องตรงกับ VIDEO_GRANT_SECRET ใน apps/video-worker/.dev.vars
VIDEO_GRANT_SECRET=dev-video-secret-change-me
# URL ของ video-worker (dev: wrangler dev รันที่ 8787); prod = โดเมน worker/custom domain
VIDEO_BASE_URL=http://localhost:8787
# อายุ grant (วินาที) — frontend จะ refresh ทุก ~ครึ่งนึงของค่านี้
VIDEO_TOKEN_TTL_SECONDS=120
