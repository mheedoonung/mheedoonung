# URL ของ backend API
VITE_API_URL=http://localhost:3000

# LIFF ID (ใส่ถ้าจะใช้ login ผ่าน LIFF บนมือถือ — ปล่อยว่างได้สำหรับ web OAuth)
VITE_LIFF_ID=

# ชื่อแอป (แสดงใน UI)
VITE_APP_NAME=mheedoonung

# ลิงก์ LINE OA ซื้อบัตรเติมเงิน (เช่น https://line.me/R/ti/p/@youroa) — ปล่อยว่าง = ซ่อนปุ่มในหน้าเว็บ
VITE_LINE_OA_URL=https://line.me/R/ti/p/@mheedoonung
